# Sarvam AI (Speech-to-Text & Text-to-Speech)
# Sign up at https://www.sarvam.ai/ to get your API key
SARVAM_API_KEY=your_sarvam_api_key_here

# Ollama (Local LLM — no API key needed, just URL and model name)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:26b

# Tuya Smart Plug (optional — get these from Tuya IoT Platform)
TUYA_DEVICE_ID=your_device_id
TUYA_ADDRESS=192.168.1.x
TUYA_LOCAL_KEY=your_local_key
TUYA_VERSION=3.5
